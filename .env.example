# ========================================
# SUPABASE (Required for UI)
# ========================================
# Get these from your Supabase project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret-key

# ========================================
# SMTP CONFIGURATION (Required)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Use App Password for Gmail
# Generate at: https://myaccount.google.com/apppasswords
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here

# ========================================
# SENDER INFORMATION (Required)
# ========================================
SENDER_NAME=Your Company Name
SENDER_EMAIL=your-email@gmail.com

# ========================================
# EMAIL CONFIGURATION
# ========================================
EMAIL_SUBJECT=Hello {{Name}}!
CSV_FILE_PATH=./data/emails.csv

# Rate Limiting (milliseconds between emails)
EMAIL_DELAY=2000

# Retry Configuration
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY=5000

# ========================================
# LOGGING (CLI mode)
# ========================================
LOG_FILE_PATH=./logs/email-log.json

# ========================================
# INLINE IMAGE (Optional)
# ========================================
INLINE_IMAGE_URL=./assets/poster.jpg

# ========================================
# API SERVER
# ========================================
PORT=3000

# Your Vercel frontend URL — restricts CORS to that origin only
# Example: https://sendy.vercel.app
ALLOWED_ORIGIN=https://your-app.vercel.app
